    <!-- Login und Registrierungs-Formular-->

    <div class="container mt-5 pt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                <!--Zwischen Login und Registrieren wechseln-->

                <ul class="nav nav-pills nav-justified mb-5" id="authTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="login-tab" data-bs-toggle="pill" data-bs-target="#login"
                            type="button" role="tab" aria-controls="login" aria-selected="true">Login</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link text-dark" id="register-tab" data-bs-toggle="pill"
                            data-bs-target="#register" type="button" role="tab" aria-controls="register"
                            aria-selected="false">Registrieren</button>
                    </li>
                </ul>

                <!--Login-Bereich-->

                <div class="tab-content" id="authContent">

                    <div class="tab-pane fade show active" id="login" role="tabpanel" aria-labelledby="login-tab">
                        <h2 class="text-center mb-4">Login</h2>



                        <form>
                            <div class="mb-4">
                                <label for="email" class="form-label">E-Mail-Adresse</label>
                                <input type="email" class="form-control" id="email" placeholder="Ihre E-Mail-Adresse">
                            </div>

                            <div class="mb-4">
                                <label for="password" class="form-label">Passwort</label>
                                <input type="password" class="form-control" id="password" placeholder="Ihr Passwort">
                            </div>

                            <button type="submit" class="btn btn-primary w-100 mb-4 py-2">Einloggen</button>

                            <div class="text-center mb-4">
                                <span>Noch kein Konto?</span>
                                <a href="#" onclick="document.getElementById('register-tab').click(); return false;"
                                    class="auth-link">Registrieren</a> </div>
                        </form>

                    </div>


                    <!--Registrieren Bereich-->
                    
                    <div class="tab-pane fade" id="register" role="tabpanel" aria-labelledby="register-tab">
                        <h2 class="text-center mb-4">Registrieren</h2>

                        <form>
                            <div class="mb-4">
                                <label for="reg-name" class="form-label">Name</label>
                                <input type="text" class="form-control" id="reg-name" placeholder="Dein Name">
                            </div>

                            <div class="mb-4">
                                <label for="reg-email" class="form-label">E-mail-Adresse</label>
                                <input type="email" class="form-control" id="reg-email"
                                    placeholder="Ihre E-Mail-Adresse">
                            </div>

                            <div class="mb-4">
                                <label for="reg-password" class="form-label">Passwort</label>
                                <input type="password" class="form-control" id="reg-password"
                                    placeholder="Passwort erstellen">
                            </div>

                            <div class="mb-4">
                                <label for="reg-password-confirm" class="form-label">Passwort bestätigen</label>
                                <input type="password" class="form-control" id="reg-password-confirm"
                                    placeholder="Passwort bestätigen">
                            </div>

                            <button type="submit" class="btn btn-primary w-100 mb-4 py-2">Kostenlos registrieren</button>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    


