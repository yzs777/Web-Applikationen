<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Balance Yoga Wiesbaden - Kurse</title>

    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
</head>

<body>

    <!-- Navigation-->
    <nav class="navbar navbar-expand-lg navbar-light bg-light fixed-top shadow-sm">
        <div class="container-fluid">

            <a class="navbar-brand" href="/">Balance Yoga Wiesbaden</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Navigation öffnen">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Startseite</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/kurse">Kursplan</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/trainer">Trainerprofile</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/workshops">Workshops & Retreats</a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/login">Login</a>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-pflaume fw-bold" href="#" id="navbarDropdown"
                            role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-user-circle me-1"></i>Mein Konto
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" href="/user-dashboard">Mein Dashboard</a></li>
                            <li><a class="dropdown-item" href="/profil-bearbeiten">Profil bearbeiten</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
                        </ul>
                    </li>
                </ul>

            </div>
        </div>
    </nav>

    <!-- Kurse -->
    <main class="container mt-5 pt-5 mb-5">
        <div class="text-center my-5">
            <h1 class="display-4 fw-bold text-pflaume">Unser Kursplan</h1>
            <p class="lead text-muted">Finde die passende Praxis für dein Erfahrungslevel und deinen Rhythmus.</p>
        </div>

        <div class="card border-0 shadow-sm p-4 mb-5 filter-card">
            <h5 class="fw-bold mb-3 text-pflaume">
                <i class="fas fa-filter me-2"></i>Kurse filtern
            </h5>

            <!-- Kurse Filter -->
            <form class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Kategorie</label>
                    <select class="form-select border-0 bg-light">
                        <option>Alle Kategorien</option>
                        <option>Entspannung</option>
                        <option>Dynamisch</option>
                        <option>Meditation</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Erfahrungslevel</label>
                    <select class="form-select border-0 bg-light">
                        <option>Alle Level</option>
                        <option>Anfänger</option>
                        <option>Mittelstufe</option>
                        <option>Fortgeschritten</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Trainer</label>
                    <select class="form-select border-0 bg-light">
                        <option>Alle Trainer</option>
                        <option>Sarah</option>
                        <option>Michael</option>
                        <option>Elena</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Tageszeit</label>
                    <select class="form-select border-0 bg-light">
                        <option>Ganztägig</option>
                        <option>Morgenkurse</option>
                        <option>Mittagkurse</option>
                        <option>Abendkurse</option>
                    </select>
                </div>
            </form>
        </div>

        <!-- Aufklappbare Termine für jeden Wochentag -->
        <div class="accordion border-0 shadow-sm course-accordion" id="courseAccordion">

            <!-- Montag -->
            <div class="accordion-item border-0 border-bottom">
                <h2 class="accordion-header">
                    <button class="accordion-button fw-bold py-3 accordion-btn-custom" type="button"
                        data-bs-toggle="collapse" data-bs-target="#collapseMontag">
                        <i class="far fa-calendar-alt me-2 text-muted"></i> Montag
                    </button>
                </h2>

                <div id="collapseMontag" class="accordion-collapse collapse show">
                    <div class="accordion-body bg-white p-4">
                        <div class="row row-cols-1 row-cols-md-2 g-4">

                            <div class="col">
                                <div class="card h-100 border-0 shadow-sm course-item-card">
                                    <div class="card-body p-4">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <span class="badge rounded-pill px-3 py-2 badge-eukalyptus">Entspannung</span>
                                            <span class="text-muted small fw-bold"><i class="far fa-clock me-1"></i> 09:00 Uhr</span>
                                        </div>

                                        <h4 class="card-title fw-bold my-2 text-pflaume">Hatha Yoga Basic</h4>
                                        <p class="card-text text-muted small mb-3">Ruhige und gehaltene Positionen zum Aufbau einer sauberen Technik und für mehr körperliche Balance.</p>
                                        <hr class="text-muted opacity-25">

                                        <div class="row g-2 mb-3 text-start small text-muted">
                                            <div class="col-6"><i class="fas fa-layer-group me-1"></i> Level: <strong>Anfänger</strong></div>
                                            <div class="col-6"><i class="fas fa-user-circle me-1"></i> Trainer: <strong>Sarah</strong></div>
                                            <div class="col-6"><i class="fas fa-door-open me-1"></i> Raum: <strong>Shanti-Raum</strong></div>
                                            <div class="col-6"><i class="fas fa-hourglass-half me-1"></i> Dauer: <strong>90 Min.</strong></div>
                                            <div class="col-6"><i class="fas fa-euro-sign me-1"></i> Preis: <strong>15,00 €</strong></div>
                                            <div class="col-6"><i class="fas fa-users me-1"></i> Plätze: <strong>20</strong></div>
                                        </div>

                                        <a href="/login" class="btn btn-primary w-100 py-2 shadow-sm btn-rounded">Jetzt Platz sichern</a>
                                    </div>
                                </div>
                            </div>

                            <div class="col">
                                <div class="card h-100 border-0 shadow-sm course-item-card">
                                    <div class="card-body p-4">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <span class="badge rounded-pill px-3 py-2 badge-eukalyptus">Dynamisch</span>
                                            <span class="text-muted small fw-bold"><i class="far fa-clock me-1"></i> 12:15 Uhr</span>
                                        </div>

                                        <h4 class="card-title fw-bold my-2 text-pflaume">Power Yoga</h4>
                                        <p class="card-text text-muted small mb-3">Ein dynamischer, schweißtreibender Flow mit Fokus auf Kraftaufbau, Ausdauer und Core-Stabilität. Perfekt, um sich richtig auszupowern.</p>
                                        <hr class="text-muted opacity-25">

                                        <div class="row g-2 mb-3 text-start small text-muted">
                                            <div class="col-6"><i class="fas fa-layer-group me-1"></i> Level: <strong>Fortgeschritten</strong></div>
                                            <div class="col-6"><i class="fas fa-user-circle me-1"></i> Trainer: <strong>Elena</strong></div>
                                            <div class="col-6"><i class="fas fa-door-open me-1"></i> Raum: <strong>Prana-Raum</strong></div>
                                            <div class="col-6"><i class="fas fa-hourglass-half me-1"></i> Dauer: <strong>45 Min.</strong></div>
                                            <div class="col-6"><i class="fas fa-euro-sign me-1"></i> Preis: <strong>12,00 €</strong></div>
                                            <div class="col-6"><i class="fas fa-users me-1"></i> Plätze: <strong>15</strong></div>
                                        </div>

                                        <a href="/login" class="btn btn-primary w-100 py-2 shadow-sm btn-rounded">Jetzt Platz sichern</a>
                                    </div>
                                </div>
                            </div>

                            <div class="col">
                                <div class="card h-100 border-0 shadow-sm course-item-card">
                                    <div class="card-body p-4">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <span class="badge rounded-pill px-3 py-2 badge-eukalyptus">Dynamisch</span>
                                            <span class="text-muted small fw-bold"><i class="far fa-clock me-1"></i> 18:30 Uhr</span>
                                        </div>

                                        <h4 class="card-title fw-bold my-2 text-pflaume">Vinyasa Flow</h4>
                                        <p class="card-text text-muted small mb-3">Fließende Bewegungen im Einklang mit dem Atem. Kraftvoll und kreativ gestaltete Sequenzen zum Feierabend.</p>
                                        <hr class="text-muted opacity-25">

                                        <div class="row g-2 mb-3 text-start small text-muted">
                                            <div class="col-6"><i class="fas fa-layer-group me-1"></i> Level: <strong>Mittelstufe</strong></div>
                                            <div class="col-6"><i class="fas fa-user-circle me-1"></i> Trainer: <strong>Michael</strong></div>
                                            <div class="col-6"><i class="fas fa-door-open me-1"></i> Raum: <strong>Prana-Raum</strong></div>
                                            <div class="col-6"><i class="fas fa-hourglass-half me-1"></i> Dauer: <strong>75 Min.</strong></div>
                                            <div class="col-6"><i class="fas fa-euro-sign me-1"></i> Preis: <strong>18,00 €</strong></div>
                                            <div class="col-6"><i class="fas fa-users me-1"></i> Plätze: <strong>15</strong></div>
                                        </div>

                                        <a href="/login" class="btn btn-primary w-100 py-2 shadow-sm btn-rounded">Jetzt Platz sichern</a>
                                    </div>
                                </div>
                            </div>

                            <div class="col">
                                <div class="card h-100 border-0 shadow-sm course-item-card">
                                    <div class="card-body p-4">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <span class="badge rounded-pill px-3 py-2 badge-eukalyptus">Meditation</span>
                                            <span class="text-muted small fw-bold"><i class="far fa-clock me-1"></i> 20:00 Uhr</span>
                                        </div>

                                        <h4 class="card-title fw-bold my-2 text-pflaume">Yin Yoga & Klang</h4>
                                        <p class="card-text text-muted small mb-3">Tiefenentspannung durch langes Halten der Positionen, begleitet von beruhigenden Klangschalen.</p>
                                        <hr class="text-muted opacity-25">

                                        <div class="row g-2 mb-3 text-start small text-muted">
                                            <div class="col-6"><i class="fas fa-layer-group me-1"></i> Level: <strong>Alle Level</strong></div>
                                            <div class="col-6"><i class="fas fa-user-circle me-1"></i> Trainer: <strong>Sarah</strong></div>
                                            <div class="col-6"><i class="fas fa-door-open me-1"></i> Raum: <strong>Lotus-Raum</strong></div>
                                            <div class="col-6"><i class="fas fa-hourglass-half me-1"></i> Dauer: <strong>60 Min.</strong></div>
                                            <div class="col-6"><i class="fas fa-euro-sign me-1"></i> Preis: <strong>15,00 €</strong></div>
                                            <div class="col-6"><i class="fas fa-users me-1"></i> Plätze: <strong>12</strong></div>
                                        </div>

                                        <a href="/login" class="btn btn-primary w-100 py-2 shadow-sm btn-rounded">Jetzt Platz sichern</a>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <!-- Hinweis: Die restlichen Wochentage aus deiner Datei können genauso bleiben.
                 Wichtig ist nur, dass alle href="login.html" zu href="/login" geändert werden. -->

        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-light text-center py-4 mt-5 border-top">
        <div class="container">
            <div class="mb-3">
                <a href="/kontakt" class="text-decoration-none text-muted me-3">Kontakt</a>
                <a href="/impressum" class="text-decoration-none text-muted me-3">Impressum</a>
                <a href="/datenschutz" class="text-decoration-none text-muted">Datenschutz</a>
            </div>
            <p class="mb-0">&copy; 2026 Balance Yoga Wiesbaden. Alle Rechte vorbehalten.</p>
        </div>
    </footer>

