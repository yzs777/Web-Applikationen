    <!--Profil bearbeiten-->

    <div class="container my-5">
        <div class="row mb-4">
            <div class="col">
                <h2 class="fw-bold text-pflaume">Profil bearbeiten</h2>
                <p class="text-muted">Verwalte hier deine persönlichen Daten </p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card card-static border-0 shadow-sm text-center p-4">
                    <div class="card-body">
                        <h3 class="h5 fw-bold text-pflaume mb-2">Max Mustermann</h3>
                        <p class="text-muted small mb-3">Mitglied seit: April 2026</p>

                        <span class="badge rounded-pill badge-eukalyptus px-3 py-2">Kundenkonto</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">

                <div class="card card-static border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h4 class="h5 fw-bold text-pflaume mb-4">Persönliche Daten</h4>

                        <form action="#">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="vorname"
                                        class="form-label text-muted small fw-bold text-uppercase">Vorname</label>
                                    <input type="text" class="form-control" id="vorname" value="Max" required>
                                </div>

                                <div class="col-md-6">
                                    <label for="nachname"
                                        class="form-label text-muted small fw-bold text-uppercase">Nachname</label>
                                    <input type="text" class="form-control" id="nachname" value="Mustermann" required>
                                </div>

                                <div class="col-md-12">
                                    <label for="email"
                                        class="form-label text-muted small fw-bold text-uppercase">E-Mail-Adresse</label>
                                    <input type="email" class="form-control" id="email" value="Max@example.com"
                                        required>
                                </div>

                                <div class="col-md-12">
                                    <label for="telefon"
                                        class="form-label text-muted small fw-bold text-uppercase">Telefonnummer
                                        (optional)</label>
                                    <input type="tel" class="form-control" id="telefon" value="+49 123 456789">
                                </div>
                            </div>

                            <div class="mt-4 text-end">
                                <button type="submit" class="btn btn-primary px-4 rounded-pill">Änderungen
                                    speichern</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card card-static border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h4 class="h5 fw-bold text-pflaume mb-4">Passwort ändern</h4>

                        <form action="#">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label for="currentPassword"
                                        class="form-label text-muted small fw-bold text-uppercase">Aktuelles
                                        Passwort</label>
                                    <input type="password" class="form-control" id="currentPassword"
                                        placeholder="••••••••" required>
                                </div>

                                <div class="col-md-6">
                                    <label for="newPassword"
                                        class="form-label text-muted small fw-bold text-uppercase">Neues
                                        Passwort</label>
                                    <input type="password" class="form-control" id="newPassword"
                                        placeholder="Mind. 8 Zeichen" required>
                                </div>

                                <div class="col-md-6">
                                    <label for="confirmPassword"
                                        class="form-label text-muted small fw-bold text-uppercase">Neues Passwort
                                        bestätigen</label>
                                    <input type="password" class="form-control" id="confirmPassword"
                                        placeholder="Mind. 8 Zeichen" required>
                                </div>
                            </div>

                            <div class="mt-4 text-end">
                                <button type="submit" class="btn btn-primary px-4 rounded-pill">Passwort
                                    aktualisieren</button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
